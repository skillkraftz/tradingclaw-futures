# TradingClaw local bind address.
TRADINGCLAW_HOST=127.0.0.1

# TradingClaw local API port.
TRADINGCLAW_PORT=8787

# Fixture directory used by the built-in file provider.
TRADINGCLAW_DATA_DIR=./data/fixtures

# Market data provider implementation to use.
TRADINGCLAW_DEFAULT_PROVIDER=file

# SQLite journal path. Parent directories are created automatically.
TRADINGCLAW_DB_PATH=./data/runtime/tradingclaw.sqlite3

# Optional webhook URL for posting rendered plan output.
TRADINGCLAW_WEBHOOK_URL=

# Optional webhook thread target. Appended as ?thread_id=... when set.
TRADINGCLAW_WEBHOOK_THREAD_ID=

# Source room label stored with persisted ideas.
TRADINGCLAW_ROOM_LABEL=trading-room

# Application log level.
TRADINGCLAW_LOG_LEVEL=INFO
